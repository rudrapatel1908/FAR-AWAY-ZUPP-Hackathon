# Project
ATHENA_ENV=development
ATHENA_LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# PostgreSQL
POSTGRES_USER=athena
POSTGRES_PASSWORD=athena_dev_password
POSTGRES_DB=athena
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://athena:athena_dev_password@localhost:5433/athena
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# JWT / Auth
JWT_SECRET_KEY=CHANGE_ME_use_a_32+_char_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# LangGraph / LLM providers
LANGGRAPH_CHECKPOINT_URI=
OPENAI_API_KEY=
